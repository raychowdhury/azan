# Azan Times — environment variables
# All keys are optional. App works without any of these on OSM data alone.

# Phase 3: verified mosque database (Supabase / PostgREST).
# When unset, the verified-DB provider becomes a graceful no-op:
# search falls back to OSM only and the public submission form is hidden.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: Google Places (New) — Nearby Search. Disabled by default.
# Setting this enables the adapter; production deploys should swap the
# fetch URL inside src/features/mosques/googlePlaces.js to a backend
# proxy so the key is not exposed in the bundle.
VITE_GOOGLE_PLACES_KEY=
